/target
.DS_Store

# Runtime output (SBOMs, provenance receipts) written by `sscsb sbom` /
# `sscsb receipt create` / `sscsb guac ingest` etc. — ephemeral, regenerated
# on demand. This is distinct from .sscsb/config.toml, .sscsb/policy/,
# .sscsb/hooks/, and .sscsb/rules/, which ARE committed: they're this repo's
# actual policy, not build output.
/.sscsb/out/

# Agent worktrees from the coverage build-out.
/.claude/
